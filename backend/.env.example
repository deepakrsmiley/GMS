PORT=8001
NODE_ENV=production

# MongoDB — use MongoDB Atlas connection string for deployment
# Example: mongodb+srv://<user>:<password>@cluster.mongodb.net/hms?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/hms

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# Cloudinary (optional — hospital logo uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=
SMTP_PASSWORD=
FROM_NAME=HMS Hospital
FROM_EMAIL=noreply@hospital.com

# Frontend URL(s) — comma-separated for CORS in production
CLIENT_URL=https://your-hms-domain.com
